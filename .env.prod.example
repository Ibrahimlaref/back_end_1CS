# Production values must come from your secret manager (Vault, AWS SM, etc.).
DJANGO_SETTINGS_MODULE=brahim.settings.prod
DEBUG=False

# Secrets (inject at runtime, never commit real values)
SECRET_KEY=replace-with-vault-secret
JWT_SECRET_KEY=replace-with-vault-jwt-secret
STRIPE_SECRET_KEY=replace-with-vault-stripe-secret

# Network and origin restrictions
ALLOWED_HOSTS=api.fittech.com
CORS_ALLOWED_ORIGINS=https://app.fittech.com
CSRF_TRUSTED_ORIGINS=https://app.fittech.com
CORS_ORIGIN_ALLOW_ALL=False

# Postgres via PgBouncer
POSTGRES_DB=fittech
POSTGRES_USER=fittech
POSTGRES_PASSWORD=replace-with-vault-db-password
DATABASE_URL=postgres://fittech:replace-with-vault-db-password@pgbouncer:5432/fittech
PGBOUNCER_ENABLED=True
DB_CONN_MAX_AGE=0
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20

# Other infra
REDIS_URL=redis://redis:6379/0
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

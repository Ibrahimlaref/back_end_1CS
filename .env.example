# Local development example only.
DJANGO_SETTINGS_MODULE=brahim.settings.dev
DEBUG=True
SECRET_KEY=dev-only-insecure-secret-key
JWT_SECRET_KEY=dev-only-jwt-secret
STRIPE_SECRET_KEY=sk_test_local_placeholder

DATABASE_URL=postgres://fittech:fittech@localhost:5432/fittech_dev
REDIS_URL=redis://localhost:6379/0
IMAGE_TAG=fittech/backend:latest
DJANGO_REPLICAS=3
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGIN_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

PGBOUNCER_ENABLED=False
DB_CONN_MAX_AGE=60
RUN_MIGRATIONS=True
